{
	"compilerOptions": {
		"declaration": true,
		"declarationMap": true,
		"exactOptionalPropertyTypes": true,
		"lib": ["ES2024", "DOM"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"target": "ES2024"
	},
	"include": ["src/**/*.ts"]
}
